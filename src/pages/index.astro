---
import App from '../components/App.jsx';
import '../styles/global.css';

const SITE_INFO = {
  title: 'CoverForge — Cover Image Generator',
  description: 'A refined cover image generator for modern content teams. Create stunning 1280×720 covers with custom typography, colors, and backgrounds.',
  url: 'https://cover.refact.cc',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{SITE_INFO.title}</title>
    <meta name="description" content={SITE_INFO.description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_INFO.url} />
    <meta property="og:title" content={SITE_INFO.title} />
    <meta property="og:description" content={SITE_INFO.description} />
    <meta property="twitter:card" content="summary_large_image" />
  </head>

  <body>
    <App client:only="react" />
  </body>
</html>
