---
import CoverGenerator from '../components/CoverGenerator.jsx';
import '../styles/global.css';

const SITE_INFO = {
  title: "Cover Generator // Workspace",
  description: "A minimal, zero-radius cover image generator for modern content teams.",
  url: "https://cover.refact.cc", 
};
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO & Meta -->
		<title>{SITE_INFO.title}</title>
		<meta name="description" content={SITE_INFO.description} />
		
		<!-- Open Graph / Twitter -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={SITE_INFO.url} />
		<meta property="og:title" content={SITE_INFO.title} />
		<meta property="og:description" content={SITE_INFO.description} />
		<meta property="twitter:card" content="summary_large_image" />
	</head>
	
	<!-- 使用系统字体，极简背景 -->
	<body class="min-h-screen font-sans selection:bg-foreground/10 selection:text-foreground overflow-x-hidden">

		<!-- 主要内容区 -->
		<main class="relative z-10 w-full min-h-screen flex flex-col">
			<CoverGenerator client:only="react" />
		</main>

	</body>
</html>